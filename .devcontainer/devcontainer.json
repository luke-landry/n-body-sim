{
    "name": "n-body-sim",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": ".."
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/dev/n-body-sim,type=bind",
    "workspaceFolder": "/home/dev/n-body-sim",
    "remoteUser": "dev",
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "mechatroner.rainbow-csv"
            ]
        }
    }
}
